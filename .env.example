# ── Public hosting (Caddy) ─────────────────────────────────────────────
# Leave blank to skip caddy locally. For local dev you can run only the
# api service (docker compose up api) at http://localhost:8000, OR add
# your domain to /etc/hosts + use mkcert to run the full stack with TLS.
DOMAIN=reframe.example.com
ACME_EMAIL=you@example.com

# Comma separated origins allowed by CORS in production.
# Use exact origin, no trailing slash.
CORS_ORIGINS=https://reframe.example.com

# Comma separated hostnames the Trusted-Host middleware will accept.
# Default "*" is fine for local dev; lock down in production.
ALLOWED_HOSTS=*

# ── LLM provider ───────────────────────────────────────────────────────
# Pick one: anthropic | xai | groq
LLM_PROVIDER=anthropic

# Anthropic (console.anthropic.com)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_FAST_MODEL=claude-haiku-4-5-20251001

# xAI Grok (console.x.ai)
XAI_API_KEY=
XAI_MODEL=grok-3
XAI_FAST_MODEL=grok-3-mini
XAI_BASE_URL=https://api.x.ai/v1

# Groq (console.groq.com). Hosts open models like Llama, fast inference.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_FAST_MODEL=llama-3.1-8b-instant
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Gemini (aistudio.google.com). Free tier, OpenAI-compatible endpoint.
GEMINI_API_KEY=
# Gemini free-tier RPD (May 2026): gemini-2.5-flash is 20/day,
# gemini-2.5-flash-lite is 1000/day. The pipeline does 6-8 LLM calls per
# tailor run, so we default to flash-lite.
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_FAST_MODEL=gemini-2.5-flash-lite
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# OpenAI (platform.openai.com). Paid, card required.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_FAST_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# ── Shared key pool ────────────────────────────────────────────────────
# Per-IP daily quota for the shared (server-side) keys. Users can bypass
# the limit by entering their own API key in the BYOK modal. Counter is
# in-memory and resets on container restart and at UTC midnight.
SHARED_DAILY_QUOTA=5

# ── Server ─────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
MAX_UPLOAD_MB=10
REQUEST_TIMEOUT_S=180
